# ---------------------------------------------------------------------------
# Paths / lake layout
# ---------------------------------------------------------------------------
DATA_ROOT=data
SQLITE_DB_PATH=data/app.db
DATA_START_DATE=2026-01-01

# ---------------------------------------------------------------------------
# ANBIMA API (required for mercado_secundario and projecoes)
# ---------------------------------------------------------------------------
ANBIMA_CLIENT_ID=your_client_id
ANBIMA_CLIENT_SECRET=your_client_secret
ANBIMA_TIMEOUT=30
ANBIMA_MAX_RETRIES=3
# ANBIMA_TOKEN_URL=https://api.anbima.com.br/oauth/access-token

# ---------------------------------------------------------------------------
# Feriados (public ANBIMA XLS — no OAuth)
# ---------------------------------------------------------------------------
FERIADOS_XLS_URL=https://www.anbima.com.br/feriados/arqs/feriados_nacionais.xls
FERIADOS_TIMEOUT=30

# ---------------------------------------------------------------------------
# BCB (NegE ZIP settlements)
# ---------------------------------------------------------------------------
BCB_BASE_URL=https://www4.bcb.gov.br/pom/demab/negociacoes/download
BCB_TIMEOUT=30
BCB_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Tesouro Nacional (auction results API)
# ---------------------------------------------------------------------------
TESOURO_BASE_URL=https://apiapex.tesouro.gov.br/aria
TESOURO_TIMEOUT=30
TESOURO_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# SIDRA / IBGE (IPCA via sidrapy)
# ---------------------------------------------------------------------------
SIDRA_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# UpToData (BMF adjustments — paid B3 files, local paths only)
# ---------------------------------------------------------------------------
UPTODATA_PASTA_INTEREST_RATE_BASE=
UPTODATA_ARQUIVO_INTEREST_RATE_BASE=Interest_Rate_SettlementPriceFile_Futures_
UPTODATA_PASTA_CURRENCY_BASE=
UPTODATA_ARQUIVO_CURRENCY_BASE=Currency_SettlementPriceFile_Futures_

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
