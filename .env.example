ANBIMA_MAX_RETRIES=3

# BCB / Tesouro Nacional
BCB_TIMEOUT=30
BCB_MAX_RETRIES=3
TESOURO_TIMEOUT=30
TESOURO_MAX_RETRIES=3

LOG_LEVEL=INFO
