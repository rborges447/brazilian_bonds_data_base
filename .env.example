# Data lake
DATA_START_DATE=2026-01-01
SQLITE_DB_PATH=data/app.db

# ANBIMA (obrigatório para mercado_secundario e projecoes)
ANBIMA_CLIENT_ID=your_client_id
ANBIMA_CLIENT_SECRET=your_client_secret
ANBIMA_TIMEOUT=30
ANBIMA_MAX_RETRIES=3

# BCB / Tesouro
BCB_TIMEOUT=30
BCB_MAX_RETRIES=3
TESOURO_TIMEOUT=30
TESOURO_MAX_RETRIES=3

# UpToData (ajustes BMF — caminhos de rede Windows)
UPTODATA_PASTA_INTEREST_RATE_BASE=X:\Interest_Rate\SettlementPrice
UPTODATA_ARQUIVO_INTEREST_RATE_BASE=Interest_Rate_SettlementPriceFile_Futures_

LOG_LEVEL=INFO
